{
  "name": "@pinwheel/capacitor-sdk",
  "version": "0.0.2",
  "description": "Capacitor plugin wrapping the Pinwheel native SDKs (supports Capacitor 6, 7, and 8)",
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/esm/index.js",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/esm/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "android/",
    "ios/",
    "Package.swift",
    "PinwheelPlugin.podspec",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && node scripts/write-cjs-package.mjs",
    "lint": "npm run eslint && npm run prettier -- --check",
    "fmt": "npm run eslint -- --fix && npm run prettier -- --write",
    "eslint": "eslint . --ext ts",
    "prettier": "prettier \"**/*.{css,html,ts,tsx,js,mjs}\"",
    "sync-public": "bash scripts/update-external-repo/main.sh",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "capacitor",
    "pinwheel",
    "plugin",
    "ios",
    "android"
  ],
  "author": "Pinwheel <dev@getpinwheel.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pinwheel-hq/pinwheel-capacitor-sdk.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@capacitor/core": ">=6.0.0 <9.0.0"
  },
  "devDependencies": {
    "@capacitor/core": "^8.0.0",
    "@ionic/eslint-config": "^0.4.0",
    "@ionic/prettier-config": "^4.0.0",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.2",
    "typescript": "^5.3.3"
  },
  "prettier": "@ionic/prettier-config",
  "eslintConfig": {
    "extends": "@ionic/eslint-config/recommended"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,html,js,mjs}": [
      "prettier --write"
    ]
  }
}
